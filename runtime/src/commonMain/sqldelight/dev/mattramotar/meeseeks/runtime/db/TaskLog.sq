import dev.mattramotar.meeseeks.runtime.TaskResult;

CREATE TABLE taskLogEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    taskId TEXT NOT NULL,
    created INTEGER NOT NULL,
    result TEXT AS TaskResult.Type NOT NULL,
    attempt INTEGER NOT NULL,
    message TEXT,
    FOREIGN KEY (taskId) REFERENCES taskSpec(id)
);

CREATE INDEX idx_taskLogEntity_taskId ON taskLogEntity(taskId);

insertLog:
INSERT INTO taskLogEntity (taskId, created, result, attempt, message)
VALUES (?, ?, ?, ?, ?);

selectLogsForTask:
SELECT * FROM taskLogEntity
WHERE taskId = ?;

-- Terminal outcomes are written as facts at log time: one-time success is
-- logged as Success, periodic per-run success as SuccessAndScheduledNext,
-- retry exhaustion as PermanentFailure, and cancellation as Cancelled. These
-- queries therefore only need to filter on the logged result type.
selectTerminalEventsForTask:
SELECT * FROM taskLogEntity
WHERE taskId = :taskId
  AND result IN (:success, :permanentFailure, :cancelled)
ORDER BY id ASC;

selectTerminalEventsSince:
SELECT * FROM taskLogEntity
WHERE id > :sinceEventId
  AND result IN (:success, :permanentFailure, :cancelled)
ORDER BY id ASC;
